# Backend Environment Variables
# Скопируй в .env и заполни своими данными

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/trading_journal"

# JWT Secret (поменяй на случайную строку)
JWT_SECRET="your_super_secret_jwt_key_change_this_in_production"

# Encryption key for API keys (32 символа)
ENCRYPTION_KEY="your_32_char_encryption_key_here!!"

# Server
PORT=3001
NODE_ENV=development

# Optional: Telegram Bot (для уведомлений)
TELEGRAM_BOT_TOKEN=""
